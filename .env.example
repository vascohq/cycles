# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_LIVEBLOCKS_API_KEY=
LIVEBLOCKS_SECRET_KEY=

# The MCP server validates Clerk OAuth tokens — no extra env vars are needed.
# Enable "Dynamic client registration" on the OAuth applications page in the
# Clerk Dashboard so MCP clients can register themselves automatically.
# Requests are authorized for any org the calling Clerk user is a member of.

# Optional: absolute origin used to build the MCP server's icon URL so remote
# clients (e.g. Claude) can render it. Resolved automatically per environment —
# production uses VERCEL_PROJECT_PRODUCTION_URL, preview uses the deployment's
# VERCEL_URL, local falls back to http://localhost:3000. Set this only to pin a
# custom production domain that differs from Vercel's.
# NEXT_PUBLIC_APP_URL=https://cycles.example.com
